<view class="page-container">
  <!-- 用户信息卡片（含统计） -->
  <view class="profile-header" wx:if="{{userInfo}}">
    <view class="avatar-wrap">
      <image class="avatar" src="{{editingProfile ? profileForm.avatarUrl || '/images/default-avatar.png' : userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" bindtap="onAvatarTap"/>
    </view>
    <view wx:if="{{editingProfile}}" class="profile-edit-box">
      <input class="profile-nickname-input" value="{{profileForm.nickname}}" placeholder="请输入昵称" bindinput="onNicknameInput"/>
      <view class="profile-edit-actions">
        <view class="btn-ghost" bindtap="cancelEditProfile">取消</view>
        <view class="btn-primary" bindtap="saveProfile">保存</view>
      </view>
    </view>
    <view wx:else bindtap="startEditProfile">
      <text class="nickname">{{userInfo.nickname || '冒险者'}}</text>
    </view>
    <text class="profile-bio">记录生活的每一个精彩瞬间</text>
    <view class="profile-stats">
      <view class="profile-stat">
        <text class="stat-num">{{stats.sagas || 0}}</text>
        <text class="stat-label">副本</text>
      </view>
      <view class="profile-stat">
        <text class="stat-num">{{stats.nodes || 0}}</text>
        <text class="stat-label">节点</text>
      </view>
      <view class="profile-stat">
        <text class="stat-num">{{stats.achievements || 0}}</text>
        <text class="stat-label">成就</text>
      </view>
    </view>
  </view>

  <!-- 菜单第一组 -->
  <view class="menu-group">
    <view class="menu-item" bindtap="goAlbums">
      <view class="menu-icon-wrap" style="background: var(--color-primary-soft);">
        <text class="menu-icon-emoji">🖼</text>
      </view>
      <text class="menu-text">我的相册</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goStats">
      <view class="menu-icon-wrap" style="background: var(--color-secondary-soft);">
        <text class="menu-icon-emoji">📊</text>
      </view>
      <text class="menu-text">数据统计</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 菜单第二组 -->
  <view class="menu-group">
    <view class="menu-item" bindtap="about">
      <view class="menu-icon-wrap" style="background: var(--color-bg-sunken);">
        <text class="menu-icon-emoji">ℹ️</text>
      </view>
      <text class="menu-text">关于人生副本</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 版本 -->
  <text class="version-text">人生副本 v1.0.0</text>
</view>
