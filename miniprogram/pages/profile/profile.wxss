/* pages/profile/profile.wxss */

/* ====== 用户信息卡片（对齐原型 profile-header） ====== */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 32rpx;
  background: var(--color-bg-surface);
}

.avatar-wrap {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  overflow: hidden;
  background: var(--color-bg-muted);
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.avatar {
  width: 100%;
  height: 100%;
}

.nickname {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.35;
  margin-bottom: 8rpx;
}

/* 个性签名 / bio */
.profile-bio {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 32rpx;
}

/* 统计数据（在 user-card 内部，居中 3 列） */
.profile-stats {
  display: flex;
  justify-content: center;
  gap: 64rpx;
}

.profile-stat {
  text-align: center;
}

.profile-stat .stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  font-family: var(--font-heading);
  color: var(--color-text-primary);
  line-height: 1.2;
}

.profile-stat .stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

/* ====== 菜单分组（对齐原型 menu-group） ====== */
.menu-group {
  background: var(--color-bg-surface);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-xs);
  overflow: hidden;
  margin-top: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
}

.menu-item + .menu-item {
  border-top: 1rpx solid var(--color-divider);
}

.menu-item:active {
  background: var(--color-bg-sunken);
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-emoji {
  font-size: 32rpx;
  line-height: 1;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.65;
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--color-text-placeholder);
}

.version-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-placeholder);
  padding: 32rpx 0;
}
