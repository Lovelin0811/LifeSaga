/* pages/stats/stats.wxss */

.stats-header {
  padding: 36rpx 0 24rpx;
}

.stats-subtitle {
  display: block;
  margin-top: 4rpx;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
}

.stats-hero {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 36rpx;
  border-radius: 28rpx;
  color: #FFF8F1;
  background: linear-gradient(135deg, #2D2520 0%, #614536 54%, #C96A48 100%);
  box-shadow: 0 16rpx 48rpx rgba(45, 37, 32, 0.18);
  overflow: hidden;
}

.hero-copy {
  position: relative;
  z-index: 1;
}

.hero-kicker {
  display: block;
  color: rgba(255, 248, 241, 0.72);
  font-size: 24rpx;
}

.hero-number-row {
  display: flex;
  align-items: flex-end;
  margin-top: 6rpx;
}

.hero-number {
  font-size: 96rpx;
  font-weight: 800;
  line-height: 0.95;
}

.hero-percent {
  margin-left: 6rpx;
  padding-bottom: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.hero-caption {
  display: block;
  margin-top: 12rpx;
  color: rgba(255, 248, 241, 0.78);
  font-size: 24rpx;
}

.hero-medal {
  position: absolute;
  right: 30rpx;
  bottom: 58rpx;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 241, 0.16);
}

.hero-medal-icon {
  font-size: 28rpx;
  line-height: 1;
}

.hero-medal-label {
  max-width: 160rpx;
  color: #FFF8F1;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-progress {
  position: relative;
  z-index: 1;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 241, 0.2);
  overflow: hidden;
}

.hero-progress-fill {
  height: 100%;
  border-radius: inherit;
  background: #FFE1A6;
}

.metric-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.metric-card {
  width: calc((100% - 16rpx) / 2);
  min-height: 156rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--color-bg-surface);
  box-shadow: var(--shadow-xs);
  box-sizing: border-box;
}

.metric-card--primary {
  background: var(--color-primary-soft);
}

.metric-label {
  display: block;
  color: var(--color-text-tertiary);
  font-size: 22rpx;
}

.metric-value {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-primary);
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.05;
}

.metric-note {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
}

.section-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: var(--color-bg-surface);
  box-shadow: var(--shadow-xs);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.section-title {
  color: var(--color-text-primary);
  font-size: 32rpx;
  font-weight: 700;
}

.section-tag {
  max-width: 280rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-sunken);
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.progress-row + .progress-row {
  margin-top: 24rpx;
}

.progress-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-label {
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.progress-value {
  color: var(--color-text-primary);
  font-size: 26rpx;
  font-weight: 700;
}

.progress-track,
.type-track {
  height: 14rpx;
  border-radius: 999rpx;
  background: var(--color-bg-sunken);
  overflow: hidden;
}

.progress-fill,
.type-fill {
  height: 100%;
  border-radius: inherit;
}

.progress-fill--done {
  background: var(--color-primary);
}

.type-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.type-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.type-main {
  width: 210rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}

.type-icon {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 26rpx;
}

.type-icon--life { background: rgba(232, 114, 90, 0.12); }
.type-icon--travel { background: rgba(90, 159, 212, 0.12); }
.type-icon--study { background: rgba(92, 184, 112, 0.12); }
.type-icon--work { background: rgba(229, 164, 77, 0.14); }
.type-icon--health { background: rgba(107, 191, 138, 0.12); }
.type-icon--creative { background: rgba(176, 136, 196, 0.12); }

.type-name {
  color: var(--color-text-primary);
  font-size: 26rpx;
  font-weight: 600;
}

.type-chart {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.type-chart .type-track {
  flex: 1;
}

.type-count {
  width: 36rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  font-weight: 700;
  text-align: right;
}

.type-fill--life { background: var(--rpg-type-life); }
.type-fill--travel { background: var(--rpg-type-travel); }
.type-fill--study { background: var(--rpg-type-study); }
.type-fill--work { background: var(--rpg-type-work); }
.type-fill--health { background: var(--rpg-type-health); }
.type-fill--creative { background: var(--rpg-type-creative); }

.empty-stats {
  margin-top: 24rpx;
  padding: 36rpx 28rpx;
  border-radius: 28rpx;
  background: var(--color-bg-surface);
  text-align: center;
}

.empty-title {
  display: block;
  color: var(--color-text-primary);
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
}
