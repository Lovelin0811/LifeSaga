/* pages/home/home.wxss */

/* 自定义导航栏 */
.home-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 32rpx;
  background: var(--color-bg-surface);
  border-bottom: 1rpx solid var(--color-border-light);
}

.home-nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.home-nav-right {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.home-nav-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.6;
}

/* Hero 区域 */
.home-header {
  padding: 32rpx 0 0;
  background: var(--color-bg-surface);
}

.greeting {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  line-height: 1.5;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  letter-spacing: -0.02em;
  line-height: 1.3;
  margin-top: 4rpx;
}

.hero-subtitle {
  display: block;
  font-size: 30rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  line-height: 1.5;
}

/* 搜索框 */
.home-search {
  margin: 24rpx 0 20rpx;
  position: relative;
  background: var(--color-bg-surface);
  padding-bottom: 20rpx;
}

.search-icon {
  position: absolute;
  left: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  margin-top: -4rpx;
}

.search-icon-img {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

.search-box {
  width: 100%;
  padding: 20rpx 32rpx 20rpx 72rpx;
  background: var(--color-bg-sunken);
  border: 3rpx solid transparent;
  border-radius: 48rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  box-sizing: border-box;
}

/* Quick Stats */
.quick-stats {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  background: var(--color-bg-surface);
  margin-bottom: 24rpx;
}

.quick-stats .stat-item {
  flex: 1;
  background: var(--color-bg-sunken);
  border-radius: 20rpx;
  padding: 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-stats .stat-num {
  font-size: 44rpx;
  font-weight: 600;
  font-family: var(--font-heading);
  color: var(--color-text-primary);
  line-height: 1.2;
}

.quick-stats .stat-label {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

/* 区块 */
.home-section {
  margin-bottom: 32rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.section-more {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

/* Instance Card 列表 */
.instance-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.instance-card {
  background: var(--color-bg-surface);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 6rpx rgba(45,37,32,0.06), 0 4rpx 16rpx rgba(45,37,32,0.04);
}

.instance-card:active {
  transform: scale(0.98);
  transition: transform 0.2s ease;
}

/* Legendary 特殊阴影 */
.instance-card--legendary {
  box-shadow: 0 2rpx 6rpx rgba(45,37,32,0.06), 0 4rpx 16rpx rgba(45,37,32,0.04), 0 0 40rpx rgba(229,164,77,0.15);
}

/* 封面 */
.instance-card .cover {
  height: 320rpx;
  position: relative;
  overflow: hidden;
}

.instance-card .cover .cover-img {
  width: 100%;
  height: 100%;
}

.instance-card .cover .cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.instance-card .cover .cover-emoji {
  font-size: 96rpx;
  opacity: 0.3;
}

/* 封面底部渐变 */
.instance-card .cover .cover-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.15));
}

/* 封面渐变背景色 */
.cover-bg-life { background: linear-gradient(135deg, #FFE5DD 0%, #FFF0EB 100%); }
.cover-bg-travel { background: linear-gradient(135deg, #EBF3FA 0%, #F5FAFF 100%); }
.cover-bg-study { background: linear-gradient(135deg, #FFF6E8 0%, #FFFBF0 100%); }
.cover-bg-work { background: linear-gradient(135deg, #EDF8F1 0%, #F5FBF7 100%); }
.cover-bg-health { background: linear-gradient(135deg, #F5EDF8 0%, #FBF7FC 100%); }
.cover-bg-creative { background: linear-gradient(135deg, #FFF0F0 0%, #FFF8F8 100%); }

/* 稀有度角标 */
.instance-card .cover .rarity-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  backdrop-filter: blur(16rpx);
}

.rarity-badge--common { background: rgba(168,176,184,0.7); color: #fff; }
.rarity-badge--uncommon { background: rgba(92,184,112,0.8); color: #fff; }
.rarity-badge--rare { background: rgba(90,159,212,0.85); color: #fff; }
.rarity-badge--epic { background: rgba(176,136,196,0.85); color: #fff; }
.rarity-badge--legendary { background: rgba(229,164,77,0.9); color: #2D2520; }

/* 卡片 body */
.instance-card .body {
  padding: 24rpx 28rpx 32rpx;
}

.instance-card .body .card-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

/* 类型标签 */
.type-tag {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.type-tag--life { background: rgba(232,114,90,0.12); color: #C04A35; }
.type-tag--travel { background: rgba(90,159,212,0.12); color: #3A7FC0; }
.type-tag--study { background: rgba(92,184,112,0.12); color: #3D9450; }
.type-tag--work { background: rgba(229,164,77,0.12); color: #C08530; }
.type-tag--health { background: rgba(107,191,138,0.12); color: #3A9B5E; }
.type-tag--creative { background: rgba(176,136,196,0.12); color: #8A5FA0; }

/* 卡片标题 */
.instance-card .body .card-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-bottom: 8rpx;
}

/* 卡片描述 */
.instance-card .body .card-desc {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

/* 卡片 meta */
.instance-card .body .card-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.instance-card .body .card-meta .meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.instance-card .body .card-meta .meta-icon {
  width: 24rpx;
  height: 24rpx;
}

/* XP 行 */
.instance-card .body .xp-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
}

.instance-card .body .xp-label {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--rpg-legendary);
  white-space: nowrap;
  font-family: var(--font-heading);
}
