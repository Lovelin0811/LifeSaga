<!--pages/home/home.wxml-->
<view class="page-container">
  <!-- 自定义导航栏 -->
  <view class="home-nav" style="padding-top: {{statusBarHeight}}px;">
    <text class="home-nav-title">人生副本</text>
    <view class="home-nav-right">
      <image src="/images/icons/search.svg" class="home-nav-icon" mode="aspectFit" bindtap="onSearchTap"/>
    </view>
  </view>

  <!-- 页面内容 -->
  <view class="home-content">
    <!-- Hero -->
    <view class="home-header">
      <text class="greeting">下午好，冒险者</text>
      <text class="hero-title">人生副本</text>
      <text class="hero-subtitle">记录你的每一段旅程</text>
    </view>

    <!-- 搜索框 -->
    <view class="home-search" bindtap="onSearchTap">
      <view class="search-icon">
        <image src="/images/icons/search.svg" class="search-icon-img" mode="aspectFit"/>
      </view>
      <text class="search-placeholder">搜索副本名称...</text>
    </view>

    <!-- Quick Stats -->
    <view class="quick-stats" wx:if="{{userInfo}}">
      <view class="stat-item">
        <text class="stat-num">{{stats.activeCount || 0}}</text>
        <text class="stat-label">进行中</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.completedCount || 0}}</text>
        <text class="stat-label">已完成</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.totalNodes || 0}}</text>
        <text class="stat-label">总节点</text>
      </view>
    </view>

    <!-- 加载中 -->
    <view class="loading-container" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:elif="{{!sagas.length}}">
      <text class="empty-text">还没有副本\n点击底部「创建」开始你的第一个冒险</text>
      <view class="btn-primary" style="margin-top: 40rpx;" bindtap="goCreate">创建第一个副本</view>
    </view>

    <!-- 副本列表 -->
    <view class="home-section" wx:else>
      <view class="section-head">
        <text class="section-title">最近副本</text>
        <text class="section-more">查看全部</text>
      </view>

      <view class="instance-list">
        <view class="instance-card {{item.rarity === 'legendary' ? 'instance-card--legendary' : ''}}"
              wx:for="{{sagas}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <!-- 封面区域 -->
          <view class="cover cover-bg-{{item.type}}">
            <image wx:if="{{item.coverUrl}}" class="cover-img" src="{{item.coverUrl}}" mode="aspectFill"/>
            <view wx:else class="cover-placeholder">
              <text class="cover-emoji">{{item.typeIcon}}</text>
            </view>
            <view class="cover-gradient"></view>
            <view class="rarity-badge rarity-badge--{{item.rarity || 'common'}}">{{item.rarityName}}</view>
          </view>
          <!-- 卡片内容 -->
          <view class="body">
            <view class="card-top">
              <text class="type-tag type-tag--{{item.type}}">{{item.typeName}}</text>
            </view>
            <text class="card-title">{{item.name}}</text>
            <text class="card-desc" wx:if="{{item.description}}">{{item.description}}</text>
            <view class="card-meta">
              <text class="meta-item">
                <image src="/images/icons/clock.svg" class="meta-icon" mode="aspectFit"/>
                {{item.startedAtText}} 开始
              </text>
              <text class="meta-item">
                <image src="/images/icons/node.svg" class="meta-icon" mode="aspectFit"/>
                {{item.nodeCount}} 个节点
              </text>
            </view>
            <view class="xp-row">
              <text class="xp-label">Lv.{{item.level || 1}}</text>
              <view class="xp-bar">
                <view class="xp-bar-fill" style="width: {{item.xpPercent || 0}}%;"></view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
