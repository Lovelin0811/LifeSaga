<view class="page-container" style="padding: 0;">
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
  </view>

  <block wx:elif="{{saga}}">
    <!-- 自定义导航栏（绝对定位，透明背景） -->
    <view class="detail-nav" style="padding-top: {{statusBarHeight}}px;">
      <view class="nav-back" bindtap="goBack">
        <image src="/images/icons/back.svg" class="nav-icon" mode="aspectFit"/>
      </view>
      <text class="nav-title">{{saga.name}}</text>
      <view class="nav-action" bindtap="showActions">
        <image src="/images/icons/more.svg" class="nav-icon" mode="aspectFit"/>
      </view>
    </view>

    <!-- 副本头部信息 -->
    <view class="detail-header" style="padding-top: {{navBarHeight}}px;">
      <view class="detail-title-row">
        <text class="type-tag type-tag--{{saga.type}}">{{saga.typeName}}</text>
        <view class="rarity-badge rarity-badge--{{saga.rarity || 'common'}}">{{saga.rarityName}}</view>
      </view>
      <text class="detail-title">{{saga.name}}</text>
      <text class="detail-desc" wx:if="{{saga.description}}">{{saga.description}}</text>
      <view class="detail-meta-row">
        <view class="node-count">
          <image src="/images/icons/node.svg" class="meta-icon-sm" mode="aspectFit"/>
          <text>{{saga.nodeCount}} 个节点</text>
        </view>
        <text wx:if="{{saga.startedAtText}}">{{saga.startedAtText}} 至今</text>
      </view>
      <view class="xp-row">
        <text class="xp-label">Lv.{{saga.level || 1}}</text>
        <view class="xp-bar">
          <view class="xp-bar-fill" style="width: {{saga.xpPercent || 0}}%;"></view>
        </view>
        <text class="xp-text">{{saga.nodeCount || 0}} / {{((saga.level || 1) * 10)}} XP</text>
      </view>
    </view>

    <!-- 时间线 -->
    <view class="timeline-container">
      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!nodes.length}}">
        <text class="empty-text">还没有节点\n开始记录这段旅程吧</text>
        <view class="add-node-card" style="margin-top: 32rpx;" bindtap="goAddNode">
          <text class="add-icon">+</text>
          <text class="add-text">添加新节点</text>
        </view>
      </view>

      <view class="timeline" wx:else>
        <view class="timeline-node {{item.milestone ? 'timeline-node--milestone' : ''}} {{item.isActive ? 'timeline-node--active' : ''}}"
              wx:for="{{nodes}}" wx:key="id"
              bindtap="goNodeDetail" data-id="{{item.id}}" data-saga-id="{{saga.id}}">
          <!-- 日期 -->
          <view class="node-date" wx:if="{{item.nodeTimeText}}">
            <text>{{item.nodeTimeText}}</text>
          </view>
          <!-- 节点卡片 -->
          <view class="node-card">
            <!-- 封面图 -->
            <view class="node-cover cover-bg-{{saga.type}}" wx:if="{{item.coverUrl || item.photos && item.photos.length}}">
              <image wx:if="{{item.coverUrl}}" class="node-cover-img" src="{{item.coverUrl}}" mode="aspectFill"/>
              <image wx:elif="{{item.photos && item.photos.length}}" class="node-cover-img" src="{{item.photos[0]}}" mode="aspectFill"
                     bindtap="previewPhoto" data-urls="{{item.photos}}" data-current="{{item.photos[0]}}"/>
            </view>
            <!-- 内容 -->
            <view class="node-content">
              <!-- 里程碑徽章 -->
              <view class="milestone-badge" wx:if="{{item.milestone}}">
                <text class="milestone-star">&#9733;</text>
                <text>里程碑</text>
              </view>
              <text class="node-title">{{item.title || '未命名节点'}}</text>
              <view class="node-location" wx:if="{{item.location}}">
                <image src="/images/icons/location.svg" class="location-icon" mode="aspectFit"/>
                <text>{{item.location}}</text>
              </view>
              <text class="node-text" wx:if="{{item.content}}">{{item.content}}</text>
              <!-- 照片预览（无封面时显示） -->
              <view class="node-photos" wx:if="{{item.photos && item.photos.length > 1 && !item.coverUrl}}">
                <image wx:for="{{item.photos}}" wx:for-item="photo" wx:key="*this"
                       class="photo-thumb" src="{{photo}}" mode="aspectFill"
                       bindtap="previewPhoto" data-urls="{{item.photos}}" data-current="{{photo}}"/>
              </view>
            </view>
          </view>
        </view>

        <!-- 添加节点入口 -->
        <view class="timeline-node timeline-node--add" bindtap="goAddNode">
          <view class="add-node-card">
            <text class="add-icon">+</text>
            <text class="add-text">添加新节点</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>

<!-- 操作面板 (编辑/删除) -->
<view class="action-sheet-mask" wx:if="{{showActionSheet}}" bindtap="hideActions">
  <view class="action-sheet" catchtap="">
    <view class="action-sheet-item action-sheet-edit" bindtap="editSaga">
      <text>编辑副本</text>
    </view>
    <view class="action-sheet-item action-sheet-delete" bindtap="deleteSaga">
      <text>删除副本</text>
    </view>
    <view class="action-sheet-cancel" bindtap="hideActions">
      <text>取消</text>
    </view>
  </view>
</view>
