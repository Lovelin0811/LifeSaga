/* pages/add-node/add-node.wxss */

/* ====== 表单页面 ====== */
.form-page {
  padding: 0 var(--space-lg) calc(32rpx + env(safe-area-inset-bottom));
}

.form-group {
  margin-bottom: 40rpx;
}

/* ====== 表单标签 ====== */
.form-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 30rpx;
  line-height: 1;
}

.label-icon-sm {
  font-size: 28rpx;
  line-height: 1;
  flex-shrink: 0;
}

/* ====== 时间选择器 readonly ====== */
.form-input-readonly {
  display: flex;
  align-items: center;
  cursor: pointer;
}

.form-input-number {
  height: 88rpx;
  padding: 0 32rpx;
}

/* ====== 地点选择器 ====== */
.location-picker {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: var(--color-bg-sunken);
  border-radius: 12px;
  transition: background 0.2s ease;
}

.location-picker:active {
  background: var(--color-primary-soft);
}

.location-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.location-placeholder {
  color: var(--color-text-placeholder);
}

.location-arrow {
  color: var(--color-text-placeholder);
  font-size: 32rpx;
  line-height: 1;
  flex-shrink: 0;
}

.location-tip {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
}

/* ====== 照片上传 ====== */
.photo-upload {
  width: 100%;
  height: 320rpx;
  background: var(--color-bg-sunken);
  border: 3rpx dashed var(--color-border-default);
  border-radius: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.photo-upload:active {
  background: var(--color-primary-soft);
  border-color: var(--color-primary);
}

.photo-upload-icon {
  font-size: 64rpx;
  opacity: 0.5;
  line-height: 1;
}

.upload-text {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

.upload-hint {
  font-size: 24rpx;
  color: var(--color-text-placeholder);
}

/* 已上传照片网格 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.photo-preview {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-sm);
}

.photo-remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.photo-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--color-border-default);
  border-radius: var(--radius-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.photo-add-icon {
  font-size: 56rpx;
  color: var(--color-text-placeholder);
  line-height: 1;
}

.photo-add-text {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
}

/* ====== 字数统计 ====== */
.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-placeholder);
  margin-top: 8rpx;
}

/* ====== 里程碑开关 ====== */
.milestone-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: var(--color-bg-sunken);
  border-radius: 12px;
}

.milestone-label {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.sort-order-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  line-height: 1.4;
}
