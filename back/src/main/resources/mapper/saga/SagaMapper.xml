<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lovelin.lifesaga.saga.infrastructure.persistence.mapper.SagaMapper">

    <resultMap id="SagaRecordMap" type="com.lovelin.lifesaga.saga.infrastructure.persistence.record.SagaRecord">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="name" column="name"/>
        <result property="type" column="type"/>
        <result property="coverUrl" column="cover_url"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="isPublic" column="is_public"/>
        <result property="nodeCount" column="node_count"/>
        <result property="rarity" column="rarity"/>
        <result property="startedAt" column="started_at"/>
        <result property="endedAt" column="ended_at"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="SagaColumns">
        id,
        user_id,
        name,
        type,
        cover_url,
        description,
        status,
        is_public,
        node_count,
        rarity,
        started_at,
        ended_at,
        created_at,
        updated_at
    </sql>

    <select id="findById" resultMap="SagaRecordMap">
        SELECT
        <include refid="SagaColumns"/>
        FROM sagas
        WHERE id = #{id}
    </select>

    <select id="findByUserId" resultMap="SagaRecordMap">
        SELECT
        <include refid="SagaColumns"/>
        FROM sagas
        WHERE user_id = #{userId}
        ORDER BY updated_at DESC
    </select>

    <select id="findPublic" resultMap="SagaRecordMap">
        SELECT
        <include refid="SagaColumns"/>
        FROM sagas
        WHERE is_public = 1
        ORDER BY updated_at DESC
    </select>

    <insert id="insert" parameterType="com.lovelin.lifesaga.saga.infrastructure.persistence.record.SagaRecord"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sagas (
            user_id,
            name,
            type,
            cover_url,
            description,
            status,
            is_public,
            node_count,
            rarity,
            started_at,
            ended_at
        ) VALUES (
            #{userId},
            #{name},
            #{type},
            #{coverUrl, jdbcType=VARCHAR},
            #{description, jdbcType=LONGVARCHAR},
            #{status},
            #{isPublic},
            #{nodeCount},
            #{rarity},
            #{startedAt, jdbcType=TIMESTAMP},
            #{endedAt, jdbcType=TIMESTAMP}
        )
    </insert>

    <update id="update" parameterType="com.lovelin.lifesaga.saga.infrastructure.persistence.record.SagaRecord">
        UPDATE sagas
        SET user_id = #{userId},
            name = #{name},
            type = #{type},
            cover_url = #{coverUrl, jdbcType=VARCHAR},
            description = #{description, jdbcType=LONGVARCHAR},
            status = #{status},
            is_public = #{isPublic},
            node_count = #{nodeCount},
            rarity = #{rarity},
            started_at = #{startedAt, jdbcType=TIMESTAMP},
            ended_at = #{endedAt, jdbcType=TIMESTAMP}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sagas
        WHERE id = #{id}
    </delete>

</mapper>
